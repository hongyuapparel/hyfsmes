PORT=3000
# 开发可用 dev_secret_123456；生产必须配置强密钥且不能使用默认值
JWT_SECRET=dev_secret_123456
JWT_EXPIRES_IN=7d

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=erp

# 首次运行后请修改或不要提交到仓库
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 小满 CRM 导入（从小满导入客户时必填）
# 从小满 CRM：企业管理 → 外部对接 → API对接 → 查看秘钥 获取
XIAOMAN_CLIENT_ID=
XIAOMAN_CLIENT_SECRET=
# 可选，默认 https://api.xiaoman.cn，沙箱用 https://api-sandbox.xiaoman.cn
# XIAOMAN_API_BASE_URL=https://api.xiaoman.cn
